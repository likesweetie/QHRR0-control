                        fullinertia="9.6e-06 9.6e-06 9.6e-06 0 0 0"/>
              <!-- <geom name="foot_visual" type="sphere" pos="-0.012 0.0 -0.037" size="0.03" material="foot_gray" group="1"/> -->
              <geom name="foot_collision" type="sphere" pos="-0.012 0.0 -0.037" size="0.03" priority="1" condim="6" friction="0.8 0.03 0.02" group="3" />
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

    <actuator>
      <motor ctrlrange="-70 70" ctrllimited="true" name="RL_hip_roll" joint="RL_hip_roll"/>
      <motor ctrlrange="-70 70" ctrllimited="true" name="RL_hip_pitch" joint="RL_hip_pitch"/>
      <motor ctrlrange="-70 70" ctrllimited="true" name="RL_knee_pitch" joint="RL_knee_pitch"/>
  </actuator>

  <sensor>
    <framequat name="base_link_quat" objtype="site" objname="base_link_imu"/>
    <gyro name="base_link_gyro" site="base_link_imu"/>
    <framequat name="imu_quat" objtype="site" objname="imu"/>
    <gyro name="imu_gyro" site="imu"/>
  </sensor>
</mujoco>
